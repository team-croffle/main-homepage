{
  "name": "croffledev-main",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint . --fix",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@nuxt/ui": "^4.8.1",
    "@tanstack/vue-query": "^5.101.0",
    "@vueuse/core": "^14.3.0",
    "clsx": "^2.1.1",
    "motion-v": "^2.2.1",
    "ofetch": "^1.5.1",
    "oidc-client-ts": "^3.5.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.34",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vue/tsconfig": "^0.9.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vue-tsc": "^3.2.8"
  },
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,json,yaml,yml,md,html}": [
      "prettier --write"
    ]
  },
  "packageManager": "yarn@4.16.0"
}
